@model ShoppingPlanner_OOP.Models.ShoppingIndexViewModel

@{
    ViewData["Title"] = "Мій список";
}

@if (TempData["Message"] is string message)
{
    <div class="alert custom-alert">@message</div>
}

<div class="page-grid">
    <div class="card custom-card">
        <h2>Бюджет</h2>

        <form asp-action="SetBudget" method="post" class="form-block">
            @Html.AntiForgeryToken()

            <label>Ліміт бюджету</label>
            <input type="number"
                   name="budgetLimit"
                   step="0.01"
                   min="0"
                   value="@Model.BudgetLimit"
                   class="form-control" />

            <button type="submit" class="btn btn-primary w-100 mt-2">Зберегти бюджет</button>
        </form>

        <div class="budget-box mt-4">
            <p><strong>Ліміт:</strong> @Model.BudgetLimit</p>
            <p><strong>Сума покупок:</strong> @Model.CurrentTotal</p>
            <p><strong>Залишок:</strong> @Model.RemainingBudget</p>
            <p>
                <strong>Статус:</strong>
                @if (Model.IsOverLimit)
                {
                    <span class="status-bad">Перевищено</span>
                }
                else
                {
                    <span class="status-good">В межах бюджету</span>
                }
            </p>
        </div>
    </div>

    <div class="card custom-card">
        <h2>Додати товар</h2>

        <form asp-action="AddItem" method="post" class="form-block">
            @Html.AntiForgeryToken()

            <label asp-for="AddItem.Name">Назва</label>
            <input asp-for="AddItem.Name" class="form-control" />
            <span asp-validation-for="AddItem.Name" class="text-danger"></span>

            <label asp-for="AddItem.Price">Ціна</label>
            <input asp-for="AddItem.Price" class="form-control" type="number" step="0.01" min="0.01" />
            <span asp-validation-for="AddItem.Price" class="text-danger"></span>

            <label asp-for="AddItem.CategoryName">Категорія</label>
            <select asp-for="AddItem.CategoryName" class="form-select">
                <option value="Food">Food</option>
                <option value="Household">Household</option>
                <option value="Electronics">Electronics</option>
            </select>
            <span asp-validation-for="AddItem.CategoryName" class="text-danger"></span>

            <button type="submit" class="btn btn-primary w-100 mt-2">Додати</button>
        </form>
    </div>
</div>

<div class="card custom-card">
    <h2>Дії</h2>

    <div class="actions-row">
        <a asp-action="Index" asp-route-sortBy="name" class="btn btn-primary">Сортувати за назвою</a>
        <a asp-action="Index" asp-route-sortBy="price" class="btn btn-primary">Сортувати за ціною</a>
        <a asp-action="Index" asp-route-sortBy="category" class="btn btn-primary">Сортувати за категорією</a>

        <form asp-action="ExportCsv" method="post" class="inline-form">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-primary">Експорт CSV</button>
        </form>
    </div>
</div>

<div class="card custom-card">
    <h2 class="center-title">Список покупок</h2>

    @if (Model.Items == null || Model.Items.Count == 0)
    {
        <p class="empty-text">Список поки порожній.</p>
    }
    else
    {
        <table class="items-table">
            <thead>
                <tr>
                    <th>Назва</th>
                    <th>Ціна</th>
                    <th>Категорія</th>
                    <th>Тип</th>
                    <th>Дія</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.Items)
                {
                    <tr>
                        <td>@item.Name</td>
                        <td>@item.Price</td>
                        <td>@item.CategoryName</td>
                        <td>@item.ItemType</td>
                        <td>
                            <form asp-action="RemoveItem" method="post" class="inline-form">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@item.Id" />
                                <button type="submit" class="btn btn-danger">Видалити</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }

    <form asp-action="ArchiveCurrentList" method="post" class="mt-4">
        @Html.AntiForgeryToken()
        <button type="submit" class="btn btn-primary">Завершити список</button>
    </form>
</div>