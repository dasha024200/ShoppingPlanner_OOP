@model ShoppingPlanner_OOP.Models.ShoppingIndexViewModel
@{
    ViewData["Title"] = "Планер";
}

@if (TempData["Message"] is string message)
{
    <div class="alert">@message</div>
}

<div class="grid-two">
    <div class="card">
        <h2>Бюджет</h2>

        <form asp-action="SetBudget" method="post" class="form-block">
            @Html.AntiForgeryToken()

            <label>Ліміт бюджету</label>
            <input type="number"
                   name="budgetLimit"
                   step="0.01"
                   min="0"
                   value="@Model.BudgetLimit" />

            <button type="submit" class="btn btn-primary">Зберегти бюджет</button>
        </form>

        <div class="budget-box">
            <p><strong>Ліміт:</strong> @Model.BudgetLimit</p>
            <p><strong>Сума покупок:</strong> @Model.CurrentTotal</p>
            <p><strong>Залишок:</strong> @Model.RemainingBudget</p>
            <p>
                <strong>Статус:</strong>
                @if (Model.IsOverLimit)
                {
                    <span class="status-bad">Перевищено</span>
                }
                else
                {
                    <span class="status-good">В межах бюджету</span>
                }
            </p>
        </div>
    </div>

    <div class="card">
        <h2>Додати товар</h2>

        <form asp-action="AddItem" method="post" class="form-block">
            @Html.AntiForgeryToken()

            <label asp-for="AddItem.Name">Назва</label>
            <input asp-for="AddItem.Name" />

            <label asp-for="AddItem.Price">Ціна</label>
            <input asp-for="AddItem.Price" type="number" step="0.01" min="0.01" />

            <label asp-for="AddItem.CategoryName">Категорія</label>
            <select asp-for="AddItem.CategoryName">
                <option value="Food">Food</option>
                <option value="Household">Household</option>
                <option value="Electronics">Electronics</option>
            </select>

            <button type="submit" class="btn btn-primary">Додати</button>
        </form>
    </div>
</div>

<div class="card actions-card">
    <h2>Дії</h2>

    <div class="actions-row">
        <a asp-action="Index" asp-route-sortBy="name" class="btn">Сортувати за назвою</a>
        <a asp-action="Index" asp-route-sortBy="price" class="btn">Сортувати за ціною</a>
        <a asp-action="Index" asp-route-sortBy="category" class="btn">Сортувати за категорією</a>

        <form asp-action="SaveJson" method="post">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn">Зберегти JSON</button>
        </form>

        <form asp-action="LoadJson" method="post">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn">Завантажити JSON</button>
        </form>

        <form asp-action="ExportCsv" method="post">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn">Експорт CSV</button>
        </form>
    </div>
</div>

<div class="card">
    <h2>Список покупок</h2>

    @if (Model.Items.Count == 0)
    {
        <p>Список поки порожній.</p>
    }
    else
    {
        <table class="items-table">
            <thead>
                <tr>
                    <th>Назва</th>
                    <th>Ціна</th>
                    <th>Категорія</th>
                    <th>Тип</th>
                    <th>Дія</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.Items)
                {
                    <tr>
                        <td>@item.Name</td>
                        <td>@item.Price</td>
                        <td>@item.Category.Name</td>
                        <td>@item.GetType().Name</td>
                        <td>
                            <form asp-action="RemoveItem" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@item.Id" />
                                <button type="submit" class="btn btn-danger">Видалити</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>