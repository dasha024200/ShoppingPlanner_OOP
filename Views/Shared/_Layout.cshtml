<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Shopping Planner</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header class="header">
        <div class="container nav-wrap">
            <a asp-controller="Shopping" asp-action="Index" class="logo">Shopping Planner</a>
            <nav>
                <a asp-controller="Shopping" asp-action="Index">Головна</a>
                <a asp-controller="Shopping" asp-action="Index">Планер</a>
            </nav>
        </div>
    </header>

    <main class="container page-content">
        @RenderBody()
    </main>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>